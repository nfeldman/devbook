# Ghostty · GRUE  →  ~/.config/ghostty/config
# Glass field, petrol ink, liminal accents. Reload a live window with Cmd+Shift+,
# (grue-phase updates the cursor color for new windows automatically).

# --- Type -------------------------------------------------------------------
font-family = "Iosevka Term"
font-size = 14
font-thicken = true
# Ligatures/contextual alternates on in the terminal; delta turns them off in diffs.
font-feature = calt
font-feature = liga
font-feature = ss20     # curly-arrow set; taste, remove if undesired

# --- Field & ink (light, glass) --------------------------------------------
background = #eef3f2
foreground = #1f2a2b
background-opacity = 1.0
minimum-contrast = 1.10   # protect legibility without flattening the palette

# selection: a calm glass, not a highlight bar
selection-background = #d7e2e1
selection-foreground = #1f2a2b

# The cursor is the grue accent — rewritten through the day by grue-phase.sh.
cursor-color = #2b7fc4 # GRUE_ACCENT
cursor-style = block
cursor-style-blink = false

# --- ANSI palette (mapped to the GRUE taxonomy) ----------------------------
# 0-7 normal, 8-15 bright. Ink, ember, jade, brass, slate, pewter-violet, teal.
palette = 0=#1f2a2b
palette = 1=#c24a2c
palette = 2=#128f74
palette = 3=#b0913f
palette = 4=#3f6f86
palette = 5=#6e7993
palette = 6=#2b8f86
palette = 7=#3a4a4c
palette = 8=#7b9498
palette = 9=#d0623a
palette = 10=#17b58a
palette = 11=#c7a651
palette = 12=#2b7fc4
palette = 13=#8a86a6
palette = 14=#2fbf98
palette = 15=#24333a

# --- Window -----------------------------------------------------------------
window-padding-x = 12
window-padding-y = 10
mouse-hide-while-typing = true
copy-on-select = true
shell-integration = zsh
shell-integration-features = cursor,sudo,title
keybind = cmd+shift+comma=reload_config
