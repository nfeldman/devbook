{
  "//": "Zed · GRUE  →  merge into ~/.config/zed/settings.json. Light-first, Iosevka, ligatures on.",
  "theme": {
    "mode": "light",
    "light": "One Light",
    "dark": "One Light"
  },
  "buffer_font_family": "IosevkaTerm Nerd Font",
  "buffer_font_size": 14.0,
  "buffer_font_features": { "calt": true, "liga": true, "ss20": true },
  "buffer_line_height": "comfortable",
  "ui_font_family": "Iosevka Aile",
  "ui_font_size": 15.0,
  "cursor_blink": false,
  "current_line_highlight": "line"
}
