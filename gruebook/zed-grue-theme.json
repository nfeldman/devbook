{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "GRUE",
  "author": "gruebook",
  "themes": [
    {
      "name": "GRUE Light",
      "appearance": "light",
      "style": {
        "background": "#eef3f2ff",
        "surface.background": "#eaf0efff",
        "elevated_surface.background": "#eaf0efff",
        "border": "#dbe4e3ff",
        "border.variant": "#e4ebeaff",
        "text": "#1f2a2bff",
        "text.muted": "#3a4a4cff",
        "text.placeholder": "#a9bcbeff",
        "text.accent": "#2b7fc4ff",
        "icon.accent": "#2b7fc4ff",
        "editor.background": "#eef3f2ff",
        "editor.foreground": "#1f2a2bff",
        "editor.gutter.background": "#eef3f2ff",
        "editor.line_number": "#a9bcbeff",
        "editor.active_line_number": "#1f2a2bff",
        "editor.active_line.background": "#f3e9d033",
        "editor.highlighted_line.background": "#f3e9d04d",
        "element.background": "#eaf0efff",
        "element.hover": "#e2ebeaff",
        "element.selected": "#d7e2e1ff",
        "ghost_element.hover": "#e2ebeaff",
        "drop_target.background": "#2b7fc433",
        "status_bar.background": "#e8efeeff",
        "title_bar.background": "#e8efeeff",
        "toolbar.background": "#eef3f2ff",
        "tab_bar.background": "#e8efeeff",
        "tab.active_background": "#eef3f2ff",
        "tab.inactive_background": "#e6edecff",
        "terminal.background": "#eef3f2ff",
        "terminal.foreground": "#1f2a2bff",
        "error": "#c24a2cff",
        "warning": "#8a6f22ff",
        "created": "#0f8a70ff",
        "modified": "#8a6f22ff",
        "deleted": "#c24a2cff",
        "conflict": "#c24a2cff",
        "hint": "#7b9498ff",
        "predictive": "#93a5a8ff",
        "syntax": {
          "comment":     { "color": "#93a5a8ff", "font_style": "italic" },
          "keyword":     { "color": "#6e7993ff" },
          "operator":    { "color": "#6e7993ff" },
          "function":    { "color": "#3f6f86ff" },
          "type":        { "color": "#8a6f22ff" },
          "constructor": { "color": "#3f6f86ff" },
          "string":      { "color": "#0f8a70ff" },
          "number":      { "color": "#2b7fc4ff" },
          "boolean":     { "color": "#2b7fc4ff" },
          "constant":    { "color": "#2b7fc4ff" },
          "variable":    { "color": "#1f2a2bff" },
          "property":    { "color": "#3f6f86ff" },
          "punctuation": { "color": "#5a6a6cff" },
          "tag":         { "color": "#6e7993ff" },
          "attribute":   { "color": "#8a6f22ff" },
          "title":       { "color": "#3f6f86ff", "font_weight": 600 },
          "emphasis":    { "color": "#1f2a2bff", "font_style": "italic" },
          "link_uri":    { "color": "#2b7fc4ff" },
          "link_text":   { "color": "#0f8a70ff" }
        }
      }
    }
  ]
}
