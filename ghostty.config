# Ghostty config  →  ~/.config/ghostty/config
# Docs: https://ghostty.org/docs/config
# Reload live with Cmd+Shift+, (or restart Ghostty).

# --- Font ---------------------------------------------------------------
font-family = "JetBrainsMono Nerd Font"
font-size = 14
font-thicken = true

# --- Theme --------------------------------------------------------------
# Run `ghostty +list-themes` to browse. Swap freely.
theme = "catppuccin-mocha"
background-opacity = 0.96
background-blur-radius = 20

# --- Window -------------------------------------------------------------
window-padding-x = 10
window-padding-y = 8
window-save-state = always
macos-titlebar-style = tabs
mouse-hide-while-typing = true
copy-on-select = true

# --- Shell integration (jump between prompts, etc.) --------------------
shell-integration = zsh
shell-integration-features = cursor,sudo,title

# --- Keybinds -----------------------------------------------------------
# Quick config reload
keybind = cmd+shift+comma=reload_config
# Clear scrollback
keybind = cmd+k=clear_screen

# NOTE: pane/tab splitting is handled by Zellij (launched from your shell),
# so Ghostty stays a clean, fast single surface. If you'd rather use
# Ghostty's own splits, add e.g.:
#   keybind = cmd+d=new_split:right
#   keybind = cmd+shift+d=new_split:down
